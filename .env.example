# CzechMedMCP Environment Variables
# Copy to .env and fill in values as needed.

# --- Optional API Keys (CzechMedMCP global tools) ---
# NCI_API_KEY=your-nci-api-key
# OPENFDA_API_KEY=your-openfda-api-key
# ONCOKB_TOKEN=your-oncokb-token
# ALPHAGENOME_API_KEY=your-alphagenome-api-key
# CBIO_TOKEN=your-cbioportal-token

# --- MCP Server Auth (optional) ---
# MCP_AUTH_TOKEN=your-mcp-auth-token

# --- Offline mode (disables all live API calls) ---
# BIOMCP_OFFLINE=false

# --- Connection pool ---
# BIOMCP_USE_CONNECTION_POOL=true

# --- Metrics ---
# BIOMCP_METRICS_ENABLED=false

# --- OpenFDA cache tuning ---
# BIOMCP_FDA_CACHE_TTL=15
# BIOMCP_FDA_MAX_CACHE_SIZE=100
# BIOMCP_FDA_MAX_RESPONSE_SIZE=1048576
# BIOMCP_SHORTAGE_CACHE_TTL=24
